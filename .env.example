# Telegram Bot Token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Optional: comma-separated allowed Telegram user IDs (e.g. "123456,789012")
# Leave empty to allow anyone
ALLOWED_CHAT_IDS=

# Ollama API host.
# For Ollama Cloud use: https://api.ollama.com
# For local Ollama use: http://localhost:11434
OLLAMA_API_HOST=https://api.ollama.com

# Model to use. Examples:
# - Ollama Cloud: kimi-k2.7-code:cloud
# - Local Ollama: llama3.2:latest
OLLAMA_BOT_MODEL=kimi-k2.7-code:cloud

# API key for Ollama Cloud.
OLLAMA_API_KEY=your_ollama_api_key_here

# Web search API key (falls back to OLLAMA_API_KEY if empty)
OLLAMA_WEB_API_KEY=

# Whisper model for voice/audio transcription (requires ffmpeg installed)
# Available: tiny, tiny.en, base, base.en, small, small.en, medium, medium.en, large-v3, turbo
WHISPER_MODEL=tiny
WHISPER_DEVICE=auto       # cpu, cuda, auto
WHISPER_COMPUTE_TYPE=default  # int8, float16, default

# News aggregator settings
# Comma-separated list of RSS feed URLs. Default covers Russian tech/business news.
DEFAULT_RSS_FEEDS=https://habr.com/ru/rss/articles/top/,https://vc.ru/rss/all,https://www.cnews.ru/inc/rss/news.xml,https://tadviser.ru/rss/news,https://lenta.ru/rss/news/it

# How many hours back to look in RSS feeds (default: 48)
RSS_NEWS_HOURS=48

# Fallback web-search provider when RSS has no fresh news.
# Supported: duckduckgo, searxng, ollama
WEB_SEARCH_PROVIDER=duckduckgo

# Optional: self-hosted SearXNG URL (only used when WEB_SEARCH_PROVIDER=searxng)
SEARXNG_URL=

# Maximum concurrent requests to Ollama. Lower this for weak/local hardware.
OLLAMA_MAX_CONCURRENT=2

# Vision model for photo analysis. Defaults to OLLAMA_BOT_MODEL if empty.
VISION_MODEL=

# Local text-to-speech (piper-tts) configuration.
# Set PIPER_MODEL to enable voice replies when the user turns on voice output.
# Example: PIPER_MODEL=ru_RU-irina-medium.onnx
PIPER_MODEL=
PIPER_MODEL_DIR=data/piper

# Region for DuckDuckGo (ru-ru for Russian results)
DUCKDUCKGO_REGION=ru-ru

# Preferred language for news filtering (ru, en)
NEWS_LANGUAGE=ru
