# Telegram Bot Token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Optional: comma-separated allowed Telegram user IDs (e.g. "123456,789012")
# Leave empty to allow anyone
ALLOWED_CHAT_IDS=

# Ollama API host.
# For Ollama Cloud use: https://api.ollama.com
# For local Ollama use: http://localhost:11434
OLLAMA_API_HOST=https://api.ollama.com

# Model to use. Examples:
# - Ollama Cloud: kimi-k2.7-code:cloud
# - Local Ollama: llama3.2:latest
OLLAMA_BOT_MODEL=kimi-k2.7-code:cloud

# API key for Ollama Cloud.
OLLAMA_API_KEY=your_ollama_api_key_here

# Web search API key (falls back to OLLAMA_API_KEY if empty)
OLLAMA_WEB_API_KEY=
