# Telegram Bot Token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Optional: comma-separated allowed Telegram user IDs (e.g. "123456,789012")
ALLOWED_CHAT_IDS=

# Ollama Cloud / Ollama API host
OLLAMA_API_HOST=http://localhost:11434

# Model to use. Examples:
# - Local Ollama: llama3.2:latest
# - Ollama Cloud: kimi-k2.7-code:cloud (use the exact name from your provider)
OLLAMA_BOT_MODEL=your-model-name:tag

# API key for Ollama Cloud / Ollama Web Search
OLLAMA_API_KEY=your_ollama_api_key_here

# Web search API key (falls back to OLLAMA_API_KEY if empty)
OLLAMA_WEB_API_KEY=
